# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Команды в чате: /winrate_range или /winrate — даты DD.MM или DD.MM DD.MM (как pnl_range)

# Автоудаление списков «резкое движение» и «пампы» через N секунд (0 = не удалять)
TELEGRAM_DELETE_ALERTS_AFTER_SEC=300

# Подсказка /winrate и текст отчёта в личке — удаление через N сек (0 = не удалять ответы бота)
TELEGRAM_WINRATE_BOT_MSG_DELETE_SEC=120

# Резолвер: какие OPEN обрабатывать по дате создания (часы). 720 ≈ 30 дней. Не «сброс раз в сутки».
OUTCOME_RESOLVER_WINDOW_HOURS=720

# Binance (публичные данные — ключи не обязательны)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# --- Ориентиры (мягкие дефолты в коде): OI/H1 только подсказки и слабые ±к score ---
# Волатильность задаётся в config.py (ATR_MIN_PCT_1H / ATR_MIN_PCT_15M), не здесь.
# OI_ORIENT_TRAP_SKIP_LONG=0
# OI_ORIENT_BONUS_SCORE=2
# OI_ORIENT_PENALTY_SCORE=0.5
# H1_ORIENT_BLOCK_MISMATCH=0
# H1_ORIENT_PENALTY_SCORE=0.25
# H1_REVERSAL_MIN_PCT=0.15
# COIN_INDICATOR_FILTER_ENABLED=0
# H1_KLINES_LIMIT=80
