# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Команды в чате: /winrate_range или /winrate — даты DD.MM или DD.MM DD.MM (как pnl_range)

# Автоудаление списков «резкое движение», «пампы», VOL и т.д. через N сек (0 = не удалять)
TELEGRAM_DELETE_ALERTS_AFTER_SEC=300
# Переопределить только дайджест VOL (movement_scanner); если не задано — как строка выше
# VOL_SCAN_TG_DELETE_AFTER_SEC=300

# Подсказка /winrate и текст отчёта в личке — удаление через N сек (0 = не удалять ответы бота)
TELEGRAM_WINRATE_BOT_MSG_DELETE_SEC=120

# Резолвер: какие OPEN обрабатывать по дате создания (часы). 720 ≈ 30 дней. Не «сброс раз в сутки».
OUTCOME_RESOLVER_WINDOW_HOURS=720

# Binance (публичные данные — ключи не обязательны)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# --- Ориентиры (мягкие дефолты в коде): OI/H1 только подсказки и слабые ±к score ---
# Волатильность задаётся в config.py (ATR_MIN_PCT_1H / ATR_MIN_PCT_15M), не здесь.
# OI_ORIENT_TRAP_SKIP_LONG=0
# OI_ORIENT_BONUS_SCORE=2
# OI_ORIENT_PENALTY_SCORE=0.5
# H1_ORIENT_BLOCK_MISMATCH=0
# H1_ORIENT_PENALTY_SCORE=0.25
# H1_REVERSAL_MIN_PCT=0.15
# COIN_INDICATOR_FILTER_ENABLED=0
# H1_KLINES_LIMIT=80

# Мин. плановый профит к зоне TP для сигналов охоты (scanner.py). Слишком высокий — пропадут LONG/SHORT, останутся только пампы/VOL.
# По умолчанию в config ~2.8; для жёсткого фильтра 4–5.
# SIGNAL_MIN_TP_MOVE_PCT=2.8
# Периодический лог охоты (scanner): торговое окно, число кандидатов. 0 = отключить.
# SCANNER_HEARTBEAT_SEC=300

# Разворот 4h→1h и 1h→15m. Без REVERSAL_ENABLED=1 модуль не сканирует рынок.
# REVERSAL_ENABLED=1
# REVERSAL_INTERVAL_SEC=600
# REVERSAL_MAX_ALERTS_PER_SCAN=5
# REVERSAL_SYMBOL_UNIVERSE=movers
# REVERSAL_MIN_QUOTE_VOL_24H=25000
# REVERSAL_INTERVAL_SEC=180
# REVERSAL_PAIR_4H_1H_ENABLED=1
# REVERSAL_PAIR_1H_15M_ENABLED=1
# REVERSAL_SHORT_ENABLED=1
# REVERSAL_LONG_ENABLED=1
# REVERSAL_CTX_4H_ROC_MIN_PCT=5.0
# REVERSAL_TRIG_1H_SWING_LOOKBACK=24

# --- Фаза 1 / PRE-PUMP (часто шумит; по умолчанию в config выключено). Вкл только если нужно:
# PHASE1_ACCUM_ENABLED=1
# PHASE1_MIN_OI_GROWTH_FRAC=0.005
# PHASE1_INTERVAL_SEC=180
# PHASE1_MAX_SYMBOLS=80
# PHASE1_CONCURRENCY=8
# PHASE1_DEDUP_SEC=7200
# PHASE1_MIN_SCORE=70
# PHASE1_RANGE_PCT_MAX=0.01
# PHASE1_SQUEEZE_BARS=3
# PHASE1_SQUEEZE_TOP_FRAC=0.15
# PHASE1_VOL_HARD_MIN=1.05
# PHASE1_USE_MACD_SCORE=1
# PHASE1_SYMBOL_UNIVERSE=movers
# PHASE1_REQUIRE_CVD_ACCEL=0
# PHASE1_REQUIRE_SQUEEZE=0
# PHASE1_REQUIRE_15M_QUIET=0

# --- SQUEEZE 5m + OI (squeeze_oi_scanner.py) ---
# Скопируй этот блок в свой .env на сервере. Без SQUEEZE_OI_ENABLED=1 модуль не запускается.
# movers = альты с движением за 24h; top = только топ по объёму (BTC/ETH — редко узкий боковик).
SQUEEZE_OI_ENABLED=0
SQUEEZE_OI_DEBUG=0
SQUEEZE_OI_SYMBOL_UNIVERSE=movers
SQUEEZE_OI_INTERVAL_SEC=180
# За один проход проверяется не весь Binance, а до N пар (см. UNIVERSE). Больше N = шире охват альтов.
SQUEEZE_OI_MAX_SYMBOLS=120
SQUEEZE_OI_CONCURRENCY=6
SQUEEZE_OI_DEDUP_SEC=3600
SQUEEZE_OI_MIN_QUOTE_VOL_24H=25000
# Только SQUEEZE+OI: отдельный чат и/или ветка форума (как в Telegram: «топик»). Пусто = как TELEGRAM_CHAT_ID.
# SQUEEZE_OI_TELEGRAM_CHAT_ID=-1001234567890
# SQUEEZE_OI_TELEGRAM_TOPIC_ID=12345
SQUEEZE_OI_KLINES_LIMIT=220
SQUEEZE_OI_HIST_LIMIT=60
SQUEEZE_OI_COMPRESS_BARS=36
# 1 = без роста OI сигнала не будет. 0 или не задавать = как в config (по умолчанию без обязательного OI).
# SQUEEZE_OI_REQUIRE_OI=0
# Пропуск проверки ATR к медиане (частый отсев)
# SQUEEZE_OI_SKIP_ATR_MEDIAN_CHECK=1
# Допуск пробоя: close >= range_high * (1 - pct/100)
# SQUEEZE_OI_BREAKOUT_RELAX_PCT=0.08
# Пороги (в коде уже мягкие дефолты; крути только если много шума)
# SQUEEZE_OI_MAX_RANGE_PCT=4.5
# SQUEEZE_OI_EMA_SPREAD_MAX_PCT=1.35
# SQUEEZE_OI_MIN_OI_GROWTH_PCT=0.35

# --- Старт пампа 5m: меньше спама — порог качества, не чаще опроса, макс. пар в сообщении
# EARLY_PUMP_MIN_QUALITY_SCORE=72
# EARLY_PUMP_INTERVAL_MIN=8
# EARLY_PUMP_MAX_ALERTS_PER_SCAN=5
# EARLY_PUMP_ENABLED=0
# EARLY_PUMP_VOL_RATIO_MAX=28
# EARLY_PUMP_MEDIAN_QUOTE_VOL_MIN=1500
# EARLY_PUMP_SIGNAL_BAR_QUOTE_VOL_MIN=0
# EARLY_PUMP_MIN_QUALITY_SCORE=48
